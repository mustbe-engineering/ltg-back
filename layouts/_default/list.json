{{- $list := slice -}}
{{- range .Pages -}}
  {{- $params := .Params -}}
  {{- $item := dict
    "id" .File.UniqueID
    "slug" .File.BaseFileName
    "title" .Title
    "date" (.Date.Format "2006-01-02T15:04:05Z07:00")
    "permalink" .RelPermalink
    "excerpt" .Summary
    "content" .Content
  -}}
  {{- $item = merge $item $params -}}
  {{- $list = $list | append $item -}}
{{- end -}}
{{- dict 
  "title" .Title 
  "permalink" .RelPermalink
  "items" $list 
| jsonify -}}
